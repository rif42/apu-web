---
import ScrollReveal from "@components/ScrollReveal.astro";
---

<section
  id="fakta-kunci"
  class="apu-section-shell relative overflow-hidden bg-brand-surface-alt"
>
  <div class="content-max py-[var(--apu-section-spacing-y)]">
    <ScrollReveal>
      <h2 class="text-h2 text-brand-primary-deeper mb-10 md:mb-12">Key Facts</h2>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <ScrollReveal delay={100}>
        <div
          class="apu-glass-card apu-interactive-card p-8 md:p-10 flex flex-col justify-center items-start"
        >
          <span class="text-h1 text-brand-primary-deep block mb-2">7</span>
          <span class="text-body-s text-brand-text-muted"
            >Excellent Study Programs</span
          >
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div
          class="apu-glass-card apu-interactive-card p-8 md:p-10 flex flex-col justify-center items-start"
        >
          <span class="text-h1 text-brand-primary-deep block mb-2">4</span>
            <span class="text-body-s text-brand-text-muted">Research Centers</span
          >
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div
          class="apu-glass-card apu-interactive-card p-8 md:p-10 flex flex-col justify-center items-start"
        >
          <span class="text-h1 text-brand-primary-deep block mb-2"
            >1990</span
          >
            <span class="text-body-s text-brand-text-muted">Foundation Established</span
          >
        </div>
      </ScrollReveal>

      <ScrollReveal delay={400}>
        <div
          class="apu-glass-card apu-interactive-card p-8 md:p-10 flex flex-col justify-center items-start"
        >
          <span class="text-h1 text-brand-primary-deep block mb-2"
            >Semarang</span
          >
          <span class="text-body-s text-brand-text-muted"
            >Jawa Tengah, Indonesia</span
          >
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
