---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import ManagementProgramHeroSection from "@sections/academic/program/ManagementProgramHeroSection.astro";
import ProgramStrengthsSection from "@sections/academic/program/ProgramStrengthsSection.astro";
import ProgramValuesSection from "@sections/academic/program/ProgramValuesSection.astro";
import ManagementProgramCareersSection from "@sections/academic/program/ManagementProgramCareersSection.astro";
import ManagementProgramFacultySection from "@sections/academic/program/ManagementProgramFacultySection.astro";
import ContactSection from "@sections/ContactSection.astro";
import Footer from "@components/Footer.astro";
import ProgramMsgFromHead from "@sections/academic/program/ProgramMsgFromHead.astro";
import ProgramStrengthsBentoSection from "@sections/academic/program/ProgramStrengthsBentoSection.astro";
import ProgramVisionMissionSection from "@sections/academic/program/ProgramVisionMissionSection.astro";
import { managementStrengthsBento } from "@data/program-strengths-bento";
import { managementProgram } from "@data/program-details";
import { managementLeadershipMessage as leadershipMessage } from "@data/academic-programs";
import BiomedicalGamePreviewSection from "@sections/academic/program/BiomedicalGamePreviewSection.astro";

---

<MainLayout
  title="Program Studi Management | Agung Putra University"
  description="Program Studi Management S1 APU — mengembangkan calon pemimpin bisnis yang adaptif, strategis, inovatif, dan siap bersaing di dunia profesional."
>
  <NavigationAPU />

  <ManagementProgramHeroSection />
  <ProgramMsgFromHead variant="light" data={leadershipMessage} />
  <!-- <BiomedicalGamePreviewSection /> -->
  <!-- <ProgramStrengthsSection /> -->
  <ProgramStrengthsBentoSection data={managementStrengthsBento} />
  <ProgramVisionMissionSection data={managementProgram} variant="management" />
  <!-- <ProgramValuesSection /> -->
  <!-- <ManagementProgramCareersSection /> -->
  <ManagementProgramFacultySection />
  <ContactSection />
  <Footer />
</MainLayout>
