---
import MainLayout from "../../layouts/MainLayout.astro";
import NavigationAPU from "../../components/NavigationAPU.astro";
import Footer from "../../components/Footer.astro";
import WireframePageHeroAPU from "../../sections/WireframePageHeroAPU.astro";
import WireframePageSectionAPU from "../../sections/WireframePageSectionAPU.astro";
---

<MainLayout title="Penerimaan Mahasiswa Baru | APU" description="Informasi jalur, timeline, dan langkah daftar mahasiswa baru APU.">
  <NavigationAPU />
  <main>
    <WireframePageHeroAPU
      kicker="Penerimaan"
      title="Mulai Pendaftaran Mahasiswa Baru APU"
      description="Pilih jalur yang sesuai potensimu, siapkan berkas, lalu kirim pendaftaran online dengan mudah."
      primaryHref="#jalur"
      primaryLabel="Pilih Jalur"
      secondaryHref="/apu/contact"
      secondaryLabel="Hubungi Tim Admisi"
    />

    <WireframePageSectionAPU
      id="jalur"
      kicker="Jalur Masuk"
      title="Pilih Jalur Pendaftaran"
      description="Dapatkan jalur yang sesuai profil akademik dan rencana biaya keluargamu."
      bullets={[
        "Jalur Reguler dengan proses seleksi bertahap dan pendampingan admin.",
        "Jalur Beasiswa untuk prestasi akademik, non-akademik, dan sosial.",
        "Konfirmasi dokumen melalui WhatsApp untuk mempercepat verifikasi.",
      ]}
      ctaHref="/apu/scholarships"
      ctaLabel="Lihat Jalur Beasiswa"
    />

    <WireframePageSectionAPU
      id="timeline"
      kicker="Gelombang"
      title="Timeline Seleksi"
      description="Rencanakan pendaftaran lebih awal agar peluang potongan biaya semakin besar."
      bullets={[
        "Gelombang I: prioritas kuota dan promo biaya formulir.",
        "Gelombang II: seleksi utama dengan jadwal wawancara terstruktur.",
        "Gelombang III: penyesuaian kuota akhir sesuai ketersediaan program.",
      ]}
    />

    <WireframePageSectionAPU
      id="simulasi-biaya"
      kicker="Simulasi"
      title="Simulasi Biaya Studi"
      description="Kalkulator biaya per program akan hadir untuk bantu keluarga menyiapkan rencana studi."
      ctaHref="/apu/contact"
      ctaLabel="Konsultasi Biaya"
    />
  </main>
  <Footer />
</MainLayout>
